{
  "name": "hf-papers-mcp",
  "version": "1.0.0",
  "description": "MCP server for Hugging Face papers \u2014 search, daily digests, metadata, citations, and indexing",
  "license": "MIT",
  "type": "commonjs",
  "main": "server.js",
  "bin": {
    "hf-papers-mcp": "server.js"
  },
